# AI Desktop Agent - Environment Variables
# Copy this file to .env and fill in your keys

# === LLM API Keys ===
# Choose ONE based on your config.yaml llm.provider setting

# DeepSeek (recommended, cheap & capable)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# MiMo (if using remote API, otherwise leave empty for local)
MIMO_API_KEY=

# Custom endpoint
CUSTOM_API_KEY=

# === HuggingFace (for Agent-S grounding model download) ===
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx

# === Optional: Proxy settings ===
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
